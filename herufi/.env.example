# Supabase — get these from your Supabase project dashboard (supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Admin email — this email gets admin access automatically
NEXT_PUBLIC_ADMIN_EMAIL=hello@herufi.org

# Site URL — used for auth redirects
NEXT_PUBLIC_SITE_URL=https://herufi.org

# Resend — get this from resend.com (herufi.org domain must be verified there
# so the contact form can send from hello@herufi.org)
RESEND_API_KEY=re_your-api-key-here
